# sdkconfig.ble — Bluedroid BLE configuration fragment for Rivr BLE support
#
# Enables the legacy ESP-IDF Bluedroid host stack instead of NimBLE.

CONFIG_BT_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=y
# CONFIG_BT_NIMBLE_ENABLED is not set

CONFIG_BT_CLASSIC_ENABLED=n
CONFIG_BT_BLE_ENABLED=y
CONFIG_BT_BLE_42_FEATURES_SUPPORTED=y

# Single GATT server use-case.
CONFIG_BT_GATTS_ENABLE=y
# CONFIG_BT_GATTC_ENABLE is not set

# Bonds are persisted in NVS by the Bluedroid stack.
CONFIG_BT_SMP_ENABLE=y
